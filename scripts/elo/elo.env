# Copy this file to scripts/elo/elo.env and adjust values for your Linux machine.

# Binary paths (or executable names in PATH)
CUTECHESS_BIN="cutechess-cli"
ORDO_BIN="ordo"

# Engine A: your Checkers UCI engine
ENGINE_A_NAME="checkers4.2"
ENGINE_A_CMD="./checkers_engine --model-name checkers4.2 --num-simulations 1600"
ENGINE_A_PROTO="uci"
ENGINE_A_OPTIONS="NumSimulations=1600;CPuct=2.5"

# Engine B: Stockfish or Stash
ENGINE_B_NAME="stash"
ENGINE_B_CMD="../stash-bot/src/stash"
ENGINE_B_PROTO="uci"
ENGINE_B_OPTIONS="Threads=4;Hash=512"

# Openings suite (required)
OPENINGS_FILE="/home/chris/8moves_v3/8moves_v3.pgn"
OPENINGS_FORMAT="pgn"
OPENINGS_ORDER="random"
OPENINGS_PLIES="16"

# Match configuration
TC="10+0.1"
GAMES="200"
CONCURRENCY="1"
TIMEMARGIN_MS="100"

# Optional adjudication (set to 1 to enable)
ENABLE_DRAW_ADJ="1"
DRAW_MOVENUMBER="40"
DRAW_MOVECOUNT="8"
DRAW_SCORE_CP="10"

ENABLE_RESIGN_ADJ="1"
RESIGN_MOVECOUNT="3"
RESIGN_SCORE_CP="600"

# Output configuration
RUN_TAG="checkers4.2_vs_stash"
RESULTS_DIR="results/elo"
PGN_NAME="matches.pgn"
CUTECHESS_LOG_NAME="cutechess.log"
ORDO_RATINGS_NAME="ordo_ratings.txt"

# Optional extra flags appended to cutechess-cli as plain tokens
# Example: "-recover -repeat"
CUTECHESS_EXTRA_ARGS=""

# Optional extra args for ORDO appended as plain tokens
ORDO_EXTRA_ARGS=""
