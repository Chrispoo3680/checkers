# Complete rating pool preset for reliable Elo estimation.
# Copy this to scripts/elo/elo.env and customize for your hardware.
#
# Strategy:
# - Use multiple anchor engines at different levels to get well-distributed wins/draws/losses.
# - Stockfish skill levels range 0-20; lower = weaker.
# - Run enough games against each anchor so scoring is meaningful (target 30-70% expected).
#
# Recommended pool (total ~1000-1200 games for < 25 Elo error):
#   - Stockfish skill 12 (medium): 400 games
#   - Stockfish skill 18 (strong): 300 games
#   - Stash (very strong): 200-300 games
#   - Stockfish skill 8 (weak): 200 games (optional, for variance)

# Binary paths (or executable names in PATH)
CUTECHESS_BIN="cutechess-cli"
ORDO_BIN="ordo"

# === POOL ENGINES ===
# Each block below defines one gauntlet opponent.
# Uncomment/comment to enable/disable that opponent.

# Engine 1: Stockfish skill 12 (medium), fast time control
POOL_ENGINE_1_NAME="stockfish-skill12"
POOL_ENGINE_1_CMD="stockfish"
POOL_ENGINE_1_PROTO="uci"
POOL_ENGINE_1_OPTIONS="Skill Level=12;Threads=2;Hash=128"
POOL_ENGINE_1_games="400"

# Engine 2: Stockfish skill 18 (strong), fast time control
POOL_ENGINE_2_NAME="stockfish-skill18"
POOL_ENGINE_2_CMD="stockfish"
POOL_ENGINE_2_PROTO="uci"
POOL_ENGINE_2_OPTIONS="Skill Level=18;Threads=2;Hash=128"
POOL_ENGINE_2_games="300"

# Engine 3: Stash (very strong)
POOL_ENGINE_3_NAME="stash"
POOL_ENGINE_3_CMD="stash"
POOL_ENGINE_3_PROTO="uci"
POOL_ENGINE_3_OPTIONS="Threads=2;Hash=128"
POOL_ENGINE_3_games="300"

# Engine 4: Stockfish skill 8 (weak), for variance
POOL_ENGINE_4_NAME="stockfish-skill8"
POOL_ENGINE_4_CMD="stockfish"
POOL_ENGINE_4_PROTO="uci"
POOL_ENGINE_4_OPTIONS="Skill Level=8;Threads=2;Hash=128"
POOL_ENGINE_4_games="200"

# === YOUR ENGINE ===
ENGINE_A_NAME="checkers4.2"
ENGINE_A_CMD="./checkers_engine"
ENGINE_A_PROTO="uci"
ENGINE_A_OPTIONS="NumSimulations=1600;CPuct=2.5"

# === COMMON MATCH SETTINGS ===
OPENINGS_FILE="/home/chris/8moves_v3/8moves_v3.pgn"
OPENINGS_FORMAT="pgn"
OPENINGS_ORDER="random"
OPENINGS_PLIES="16"

# Time control: fast iteration (10+0.1) or longer (30+0.3) for release quality.
TC="10+0.1"
CONCURRENCY="1"
TIMEMARGIN_MS="100"

# Adjudication settings
ENABLE_DRAW_ADJ="1"
DRAW_MOVENUMBER="40"
DRAW_MOVECOUNT="8"
DRAW_SCORE_CP="10"

ENABLE_RESIGN_ADJ="1"
RESIGN_MOVECOUNT="3"
RESIGN_SCORE_CP="600"

# === OUTPUT ===
RESULTS_DIR="../../../mnt/shared/checkers_data/results/elo"
RUN_TAG="checkers4.2_rating-pool-$(date +%Y%m%d_%H%M%S)"
PGN_NAME="matches.pgn"
CUTECHESS_LOG_NAME="cutechess.log"
ORDO_RATINGS_NAME="ordo_ratings.txt"
GAUNTLET_SUMMARY_NAME="gauntlet_summary.txt"

# Optional cutechess extra args
CUTECHESS_EXTRA_ARGS=""

# Optional ordo extra args
ORDO_EXTRA_ARGS=""
